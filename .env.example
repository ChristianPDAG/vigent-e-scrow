# ============================================================
# Vigent Escrow — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA comitees .env (está en .gitignore)
# ============================================================

# Solana Program ID (igual en localnet/devnet/mainnet si mismo keypair)
NEXT_PUBLIC_PROGRAM_ID=bzopvkvUsqbUCy47wWmkvR53U2GecG9ZJD7yQg3cDtp

# Token USDC
# Devnet (mock creado por init_devnet.ts):  se genera dinámicamente
# Mainnet:                                  EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=<pubkey_del_mint_usdc>

# Wallet que recibe las comisiones de la plataforma (2.5%)
NEXT_PUBLIC_TREASURY_PUBKEY=<pubkey_treasury>

# Wallet autorizada para resolver disputas
NEXT_PUBLIC_ARBITER_PUBKEY=<pubkey_arbiter>

# RPC URL
# Localnet: http://localhost:8899
# Devnet:   https://api.devnet.solana.com
# Mainnet:  https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Cluster actual
# Valores válidos: localnet | devnet | mainnet-beta
NEXT_PUBLIC_CLUSTER=devnet

# Supabase (opcional, para indexar escrows off-chain)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
