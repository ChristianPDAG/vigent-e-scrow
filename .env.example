# ============================================================
# Vigent Escrow — Variables de Entorno
# Copia este archivo como .env.local en web/ y completa los valores
# Para Vercel: pegarlas en Settings → Environment Variables
# NUNCA comitees .env (está en .gitignore)
# ============================================================

# ─── REQUERIDAS PARA EL FRONTEND (web/) ──────────────────────

# Cluster: devnet | mainnet-beta | localnet
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC URL
# Devnet:   https://api.devnet.solana.com
# Mainnet:  https://api.mainnet-beta.solana.com  (recomendado: Helius/QuickNode)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID del contrato Escrow desplegado en devnet
NEXT_PUBLIC_ESCROW_PROGRAM_ID=GJpDE682RqjTKT75Hjii3KqUaW5ddhwqLWy1afH4XR5u

# Mint del token USDC
# Devnet (mock creado por init_devnet.ts): pubkey dinámico — usar el del .env real
# Mainnet:                                  EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Wallet que recibe las comisiones de la plataforma (2.5%)
NEXT_PUBLIC_TREASURY=3GjWHR8sPau4sXGvh6U9dPzqQWvZLWPmi9dEDgSYjLcJ

# Set true para usar el mock service (sin llamadas on-chain)
NEXT_PUBLIC_USE_MOCK=false

# ─── BACKEND / SCRIPTS (no van a Vercel) ─────────────────────

# Wallet autorizada para resolver disputas (mismo que TREASURY en devnet)
NEXT_PUBLIC_ARBITER_PUBKEY=3GjWHR8sPau4sXGvh6U9dPzqQWvZLWPmi9dEDgSYjLcJ

# ─── SUPABASE (opcional, indexador off-chain) ────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
